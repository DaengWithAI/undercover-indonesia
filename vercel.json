{
  "functions": {
    "api/random-pair.ts": {
      "includeFiles": "node_modules/@upstash/redis/**"
    },
    "api/words.ts": {
      "includeFiles": "node_modules/@upstash/redis/**"
    },
    "api/migrate.ts": {
      "includeFiles": "node_modules/@upstash/redis/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}